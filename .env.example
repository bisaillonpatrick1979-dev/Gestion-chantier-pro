# Supabase public frontend variables
# Copy this file to .env.local for local development.
# In Vercel, add the same variables in Project Settings > Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# IMPORTANT:
# Never put SUPABASE_SERVICE_ROLE_KEY in this frontend app.
# The service role key must stay server-side only.

# Anthropic Managed Agents — SERVER-SIDE ONLY (jamais de préfixe NEXT_PUBLIC_)
# Ajoutez ces 4 variables dans Vercel > Project Settings > Environment Variables
# Clé API : console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# IDs de l'agent créé dans console.anthropic.com → Agents
ANTHROPIC_AGENT_ID=agent_01XUzapdq2DPFR7RQ9eHyXei
ANTHROPIC_ENVIRONMENT_ID=env_01NUwGtfQBaT2qAGhsMX2TjV
ANTHROPIC_VAULT_ID=vlt_011CbbiZV5F97ZMF6arEhfet
