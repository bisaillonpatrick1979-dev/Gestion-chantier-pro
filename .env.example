# Supabase public frontend variables
# Copy this file to .env.local for local development.
# In Vercel, add the same variables in Project Settings > Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# IMPORTANT:
# Never put SUPABASE_SERVICE_ROLE_KEY in this frontend app.
# The service role key must stay server-side only.

# Anthropic API — SERVER-SIDE ONLY (jamais de préfixe NEXT_PUBLIC_)
# Ajoutez cette variable dans Vercel > Project Settings > Environment Variables
# Obtenez votre clé sur console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
