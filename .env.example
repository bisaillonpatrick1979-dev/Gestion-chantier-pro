# =============================================
# GESTION CHANTIER PRO — Variables d'environnement
# =============================================
# Copiez ce fichier en .env.local pour le développement local.
# Dans Vercel: Project Settings → Environment Variables

# --- SUPABASE (PUBLIC — préfixe NEXT_PUBLIC_ requis) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --- SUPABASE SERVICE ROLE (SERVER-SIDE ONLY — jamais de NEXT_PUBLIC_) ---
# Permet à l'agent IA de lire les données Supabase en contournant les RLS
# Trouvez cette clé: Supabase Dashboard → Settings → API → service_role key
# ⚠️ NE JAMAIS exposer cette clé côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ANTHROPIC (SERVER-SIDE ONLY) ---
# Clé API: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- ANTHROPIC MANAGED AGENTS (OPTIONNEL) ---
# Si configuré → utilise les Managed Agents Anthropic
# Si non configuré → utilise directement l'API Claude (mode automatique)
# IDs créés dans console.anthropic.com → Agents
ANTHROPIC_AGENT_ID=agent_01XUzapdq2DPFR7RQ9eHyXei
ANTHROPIC_ENVIRONMENT_ID=env_01NUwGtfQBaT2qAGhsMX2TjV
ANTHROPIC_VAULT_ID=vlt_011CbbiZV5F97ZMF6arEhfet

# --- AGENT CONTEXT SECRET (OPTIONNEL) ---
# Protège l'endpoint /api/agent/context (données Supabase pour l'agent)
# Si non défini, l'endpoint est désactivé publiquement
AGENT_CONTEXT_SECRET=your-secret-key-here
