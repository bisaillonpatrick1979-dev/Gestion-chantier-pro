# Supabase public frontend variables
# Copy this file to .env.local for local development.
# In Vercel, add the same variables in Project Settings > Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# IMPORTANT:
# Never put SUPABASE_SERVICE_ROLE_KEY in this frontend app.
# The service role key must stay server-side only.

# ─── Anthropic Managed Agents (IA Assistant) ─────────────────────────────────
# 1. Ajoutez votre clé API Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# 2. Exécutez `npm run create-agent` UNE SEULE FOIS pour créer l'agent et l'environnement.
#    Copiez les IDs affichés dans le terminal ci-dessous.
AGENT_ID=agent_...
ENVIRONMENT_ID=env_...

# 3. OPTIONNEL — Requis seulement si vous utilisez OAuth MCP (GitHub/Supabase/Vercel).
#    Créez un vault via l'API Anthropic et collez son ID ici.
VAULT_ID=
